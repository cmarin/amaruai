# App environment (development, production)
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_BUCKET=your-bucket-name

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# OpenRouter (optional)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# CORS - comma-separated list of additional allowed origins
CORS_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# Whisper (optional)
WHISPER_API=your-whisper-api-url
WHISPER_MODEL=your-whisper-model

# OCR (optional)
EASYOCR_MODULE_PATH=

# Internal service key (optional)
SERVICE1_API_KEY=
